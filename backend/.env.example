# Kick API credentials (never expose these in the frontend!)
KICK_CLIENT_ID=your_kick_client_id_here
KICK_CLIENT_SECRET=your_kick_client_secret_here

# The redirect URI registered in the Kick Developer Portal
# For production: https://your-domain.com/
# For local dev: http://localhost:3000/
REDIRECT_URI=http://localhost:3000/

# Discord webhook URL for stream-online notifications
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/YOUR_ID/YOUR_TOKEN

# Port for the backend server (optional, defaults to 3001)
PORT=3001

# Comma-separated list of allowed origins for CORS
# e.g. https://rickr18.github.io,http://localhost:5500
ALLOWED_ORIGINS=https://rickr18.github.io
